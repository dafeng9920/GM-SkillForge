      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [2450, -150],
      "notes": "成功通知：外部 Skill 入主仓"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.NOTIFICATION_WEBHOOK_FAILURE }}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"status\": \"BLOCKED\",\n  \"run_id\": \"{{ $(\"Call Boundary Check\").item.json.run_id || 'N/A' }}\",\n  \"gate_decision\": \"{{ $(\"Call Boundary Check\").item.json.gate_decision || 'DENY' }}\",\n  \"error_code\": \"{{ $json.error_code || $(\"Call Boundary Check\").item.json.error_code || 'UNKNOWN' }}\",\n  \"blocked_by\": \"{{ $json.blocked_by || $(\"Call Boundary Check\").item.json.blocked_by || 'GATE' }}\",\n  \"message\": \"{{ $json.message || $(\"Call Boundary Check\").item.json.message || 'Import blocked' }}\",\n  \"required_changes\": {{ JSON.stringify($json.required_changes || $(\"Call Boundary Check\").item.json.required_changes || []) }},\n  \"evidence_ref\": \"{{ $(\"Call Boundary Check\").item.json.evidence_ref || 'N/A' }}\",\n  \"tombstone\": {{ JSON.stringify($json.tombstone || null) }},\n  \"auto_retry\": false,\n  \"note\": \"Business errors (E001-E108) must not auto-retry\",\n  \"n8n_execution_id\": \"{{ $executionId }}\",\n  \"timestamp\": \"{{ $now.toISO() }}\"\n}",
        "options": {}
      },
      "id": "notify-failure-external",
      "name": "Notify Failure",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [2450, 50],
      "notes": "失败通知：fail-closed，包含 required_changes"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.NOTIFICATION_WEBHOOK_ERROR }}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"status\": \"E001_PERMIT_REQUIRED\",\n  \"error_code\": \"E001\",\n  \"blocked_by\": \"PERMIT_REQUIRED\",\n  \"message\": \"Permit is required for external skill import\",\n  \"required_changes\": [{\"field\": \"permit_refs\", \"issue\": \"empty\", \"fix\": \"Obtain a valid import permit before retrying\"}],\n  \"external_skill_ref\": \"{{ $(\"Check Forbidden Fields\").item.json.input.external_skill_ref }}\",\n  \"auto_retry\": false,\n  \"n8n_execution_id\": \"{{ $executionId }}\",\n  \"timestamp\": \"{{ $now.toISO() }}\"\n}",
        "options": {}
      },
      "id": "notify-permit-missing",
      "name": "Notify Permit Missing",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [1250, 200],
      "notes": "E001 无 Permit 阻断通知"
    },
