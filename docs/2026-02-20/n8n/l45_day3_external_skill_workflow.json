        "url": "={{ $env.NOTIFICATION_WEBHOOK_ERROR }}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"status\": \"FORBIDDEN_FIELD_DETECTED\",\n  \"error_code\": \"{{ $(\"Check Forbidden Fields\").item.json.error_code }}\",\n  \"error_message\": \"{{ $(\"Check Forbidden Fields\").item.json.error_message }}\",\n  \"forbidden_fields\": {{ JSON.stringify($(\"Check Forbidden Fields\").item.json.forbidden_fields || []) }},\n  \"n8n_execution_id\": \"{{ $executionId }}\",\n  \"auto_retry\": false,\n  \"timestamp\": \"{{ $now.toISO() }}\"\n}",
        "options": {}
      },
      "id": "notify-forbidden-field-external",
      "name": "Notify Forbidden Field",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [1050, 300],
