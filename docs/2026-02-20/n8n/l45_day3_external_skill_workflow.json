{
  "name": "L4.5 Day-3 External Skill Governance Workflow",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "webhook/skillforge/external-skill/import",
        "responseMode": "onReceived",
        "options": {}
      },
      "id": "trigger-external-skill-import",
      "name": "Webhook Trigger",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [250, 300],
      "webhookId": "skillforge-external-skill-import",
      "notes": "接收外部 Skill 导入请求"
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{ $json.external_skill_ref }}",
              "operation": "isNotEmpty"
            },
            {
              "value1": "={{ $json.repo_url }}",
              "operation": "isNotEmpty"
            },
            {
              "value1": "={{ $json.commit_sha }}",
              "operation": "isNotEmpty"
            },
            {
              "value1": "={{ $json.at_time }}",
              "operation": "isNotEmpty"
            }
          ]
        },
        "options": {}
      },
      "id": "validate-external-skill-input",
      "name": "Validate Required Fields",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [450, 300],
      "notes": "校验必填字段：external_skill_ref, repo_url, commit_sha, at_time"
    },
    {
      "parameters": {
        "jsCode": "// 检查禁止字段（越权防护）\nconst input = $input.item.json;\nconst forbiddenFields = ['gate_decision', 'release_allowed', 'evidence_ref', 'permit_id', 'run_id', 'permit_token'];\nconst detected = forbiddenFields.filter(f => input.hasOwnProperty(f));\n\nif (detected.length > 0) {\n  return {\n    json: {\n      forbidden_detected: true,\n      forbidden_fields: detected,\n      error_code: 'N8N-FORBIDDEN-FIELD',\n      error_message: `Forbidden fields detected: ${detected.join(', ')}. n8n cannot inject these fields.`\n    }\n  };\n}\n\n// 检查 at_time 是否为漂移值\nconst driftValues = ['latest', 'now', 'current', 'today', 'yesterday', 'tomorrow', 'recent', 'newest'];\nif (driftValues.includes(input.at_time?.toLowerCase())) {\n  return {\n    json: {\n      forbidden_detected: true,\n      error_code: 'N8N-AT-TIME-FIXED-REQUIRED',\n      error_message: `at_time must be a fixed ISO-8601 timestamp. '${input.at_time}' is not allowed.`\n    }\n  };\n}\n\n// 检查 permit_refs\nif (!input.permit_refs || input.permit_refs.length === 0) {\n  return {\n    json: {\n      forbidden_detected: false,\n      permit_missing: true,\n      input: input\n    }\n  };\n}\n\nreturn {\n  json: {\n    forbidden_detected: false,\n    permit_missing: false,\n    input: input\n  }\n};"
      },
      "id": "check-forbidden-fields-external",
      "name": "Check Forbidden Fields",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [650, 200],
      "notes": "检测越权字段 + at_time 漂移值 + permit 缺失"
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{ $json.forbidden_detected }}",
              "value2": false
            }
          ]
        },
        "options": {}
      },
      "id": "route-forbidden-check-external",
      "name": "Route Forbidden Check",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [850, 200],
      "notes": "越权字段检测路由"
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{ $json.permit_missing }}",
              "value2": false
            }
          ]
        },
        "options": {}
      },
      "id": "route-permit-check",
      "name": "Route Permit Check",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [1050, 100],
      "notes": "Permit 存在性检测路由（no-permit-no-import）"
    },
    {
      "parameters": {
        "url": "={{ $env.SKILLFORGE_API_BASE }}/api/v1/external-skill/boundary-check",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "httpMethod": "POST",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"external_skill_ref\": \"{{ $(\"Check Forbidden Fields\").item.json.input.external_skill_ref }}\",\n  \"repo_url\": \"{{ $(\"Check Forbidden Fields\").item.json.input.repo_url }}\",\n  \"commit_sha\": \"{{ $(\"Check Forbidden Fields\").item.json.input.commit_sha }}\",\n  \"at_time\": \"{{ $(\"Check Forbidden Fields\").item.json.input.at_time }}\",\n  \"permit_refs\": {{ JSON.stringify($(\"Check Forbidden Fields\").item.json.input.permit_refs || []) }},\n  \"n8n_execution_id\": \"{{ $executionId }}\"\n}",
        "options": {
          "timeout": 60000,
          "retry": {
            "enabled": true,
            "maxRetries": 3,
            "retryInterval": 5000
          }
        }
      },
      "id": "call-boundary-check",
      "name": "Call Boundary Check",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [1250, 50],
      "notes": "调用 SkillForge 边界检查（E001-E007）",
      "credentials": {
        "httpHeaderAuth": {
          "id": "skillforge-api-auth",
          "name": "SkillForge API Auth"
        }
      }
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{ $json.ok }}",
              "value2": true
            }
          ]
        },
        "options": {}
      },
      "id": "route-boundary-result",
      "name": "Route Boundary Result",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [1450, 50],
      "notes": "边界检查结果路由"
    },
    {
      "parameters": {
        "url": "={{ $env.SKILLFORGE_API_BASE }}/api/v1/external-skill/quarantine",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "httpMethod": "POST",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"run_id\": \"{{ $(\"Call Boundary Check\").item.json.run_id }}\",\n  \"external_skill_ref\": \"{{ $(\"Check Forbidden Fields\").item.json.input.external_skill_ref }}\",\n  \"repo_url\": \"{{ $(\"Check Forbidden Fields\").item.json.input.repo_url }}\",\n  \"commit_sha\": \"{{ $(\"Check Forbidden Fields\").item.json.input.commit_sha }}\",\n  \"at_time\": \"{{ $(\"Check Forbidden Fields\").item.json.input.at_time }}\",\n  \"n8n_execution_id\": \"{{ $executionId }}\"\n}",
        "options": {
          "timeout": 120000,
          "retry": {
            "enabled": true,
            "maxRetries": 3,
            "retryInterval": 5000
          }
        }
      },
      "id": "call-quarantine",
      "name": "Call Quarantine",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [1650, 0],
      "notes": "调用隔离检查（E101-E103）",
      "credentials": {
        "httpHeaderAuth": {
          "id": "skillforge-api-auth",
          "name": "SkillForge API Auth"
        }
      }
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{ $json.ok }}",
              "value2": true
            }
          ]
        },
        "options": {}
      },
      "id": "route-quarantine-result",
      "name": "Route Quarantine Result",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [1850, 0],
      "notes": "隔离检查结果路由"
    },
    {
      "parameters": {
        "url": "={{ $env.SKILLFORGE_API_BASE }}/api/v1/external-skill/l1-l5-audit",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "httpMethod": "POST",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"run_id\": \"{{ $(\"Call Boundary Check\").item.json.run_id }}\",\n  \"evidence_ref\": \"{{ $(\"Call Quarantine\").item.json.evidence_ref }}\",\n  \"n8n_execution_id\": \"{{ $executionId }}\"\n}",
        "options": {
          "timeout": 300000,
          "retry": {
            "enabled": true,
            "maxRetries": 3,
            "retryInterval": 5000
          }
        }
      },
      "id": "call-l1-l5-audit",
      "name": "Call L1-L5 Audit",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [2050, -50],
      "notes": "调用 L1-L5 五层审计（E104-E108）",
      "credentials": {
        "httpHeaderAuth": {
          "id": "skillforge-api-auth",
          "name": "SkillForge API Auth"
        }
      }
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{ $json.gate_decision || $(\"Call Boundary Check\").item.json.gate_decision }}",
              "value2": "ALLOW",
              "operation": "equals"
            }
          ]
        },
        "options": {}
      },
      "id": "route-final-gate-decision-external",
      "name": "Route by gate_decision",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [2250, -50],
      "notes": "仅消费 SkillForge 返回的 gate_decision"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.NOTIFICATION_WEBHOOK_SUCCESS }}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"status\": \"SUCCESS\",\n  \"run_id\": \"{{ $(\"Call Boundary Check\").item.json.run_id }}\",\n  \"gate_decision\": \"{{ $(\"Call Boundary Check\").item.json.gate_decision }}\",\n  \"evidence_ref\": \"{{ $(\"Call L1-L5 Audit\").item.json.evidence_ref }}\",\n  \"release_allowed\": \"{{ $(\"Call L1-L5 Audit\").item.json.release_allowed }}\",\n  \"replay_pointer\": \"{{ $(\"Call L1-L5 Audit\").item.json.replay_pointer }}\",\n  \"external_skill_ref\": \"{{ $(\"Check Forbidden Fields\").item.json.input.external_skill_ref }}\",\n  \"registry_admission\": \"{{ $(\"Call L1-L5 Audit\").item.json.registry_admission }}\",\n  \"revision\": \"{{ $(\"Call L1-L5 Audit\").item.json.revision }}\",\n  \"n8n_execution_id\": \"{{ $executionId }}\",\n  \"timestamp\": \"{{ $now.toISO() }}\"\n}",
        "options": {}
