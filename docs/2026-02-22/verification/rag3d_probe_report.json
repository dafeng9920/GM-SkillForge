  "reproduction_steps": {
    "description": "RAG 3D 能力复现实验步骤",
    "steps": [
      {
        "step_id": "STEP-001",
        "name": "环境准备",
        "commands": [
          "cd d:/GM-SkillForge",
          "python -c \"import sys; sys.path.insert(0, 'skillforge/src')\""
        ],
        "expected_result": "Python 环境就绪"
      },
      {
        "step_id": "STEP-002",
        "name": "导入 RAG Adapter",
        "commands": [
          "from adapters.rag_adapter import MockRAGAdapter, AT_TIME_FORBIDDEN_VALUES"
        ],
        "expected_result": "成功导入 MockRAGAdapter 和禁止值列表"
      },
      {
        "step_id": "STEP-003",
        "name": "测试 at_time 漂移值拒绝",
        "commands": [
          "adapter = MockRAGAdapter()",
          "for drift in ['latest', 'now', 'current']:",
          "    try:",
          "        adapter.query(query='test', at_time=drift)",
          "        print(f'FAIL: {drift} should be rejected')",
          "    except ValueError:",
          "        print(f'PASS: {drift} correctly rejected')"
        ],
        "expected_result": "所有漂移值被正确拒绝"
      },
      {
        "step_id": "STEP-004",
        "name": "测试有效 ISO-8601 接受",
        "commands": [
          "result = adapter.query(query='test', at_time='2026-02-22T10:00:00Z')",
          "assert result.at_time == '2026-02-22T10:00:00Z'",
          "assert result.replay_pointer is not None",
          "print('PASS: Valid ISO-8601 accepted with replay_pointer')"
        ],
        "expected_result": "有效时间戳被接受，replay_pointer 正确输出"
      },
      {
        "step_id": "STEP-005",
        "name": "测试 replay_pointer 完整性",
        "commands": [
          "result = adapter.query(",
          "    query='test query',",
          "    at_time='2026-02-22T10:00:00Z',",
          "    repo_url='https://github.com/test/repo',",
          "    commit_sha='a1b2c3d4e5f6789012345678901234567890abcd'",
          ")",
          "assert result.replay_pointer['at_time'] == '2026-02-22T10:00:00Z'",
          "assert result.replay_pointer['repo_url'] == 'https://github.com/test/repo'",
          "assert result.replay_pointer['commit_sha'] == 'a1b2c3d4e5f6789012345678901234567890abcd'",
          "assert 'run_id' in result.replay_pointer"
        ],
        "expected_result": "replay_pointer 包含所有必要字段"
      },
      {
        "step_id": "STEP-006",
        "name": "测试 Experience Capture",
        "commands": [
          "from skills.experience_capture import ExperienceCaptureV0",
          "capture = ExperienceCaptureV0()",
          "result = capture.capture(",
          "    issue_key='PROBE-TEST-001',",
          "    evidence_ref='file://test/evidence.json',",
          "    gate_node='probe_test',",
          "    summary='RAG 3D probe test entry',",
          "    fix_kind='GATE_DECISION'",
          ")",
          "assert result['status'] in ['CAPTURED', 'SKIPPED_DUPLICATE']"
        ],
        "expected_result": "Experience 成功捕获或去重跳过"
      },
      {
        "step_id": "STEP-007",
        "name": "验证 evolution.json",
        "commands": [
          "import json",
          "with open('AuditPack/experience/evolution.json') as f:",
          "    data = json.load(f)",
          "assert 'schema_version' in data",
          "assert 'entries' in data",
          "print(f'entries count: {len(data[\"entries\"])}')"
        ],
        "expected_result": "evolution.json 结构正确"
      },
      {
        "step_id": "STEP-008",
        "name": "运行 RAG 生产测试",
        "commands": [
          "cd skillforge",
          "python -m pytest tests/test_n8n_query_rag_production.py -v"
        ],
        "expected_result": "所有测试通过"
      }
    ],
