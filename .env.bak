# =====================================================================
# NEW-GM Common Environment Configuration
# 公共配置 - 由所有服务共享
#
# 加载顺序:
#   1. .env (本文件 - 公共配置)
#   2. .env.inner (内网专用) 或 .env.outer (外网专用)
# =====================================================================

# =====================================================================
# Cloud LLM Configuration (OpenAI compatible)
# 支持 GLM/GPT/MiniMax 等各种模型
# =====================================================================
CLOUD_LLM_MODEL=GLM-4.7-Flash
CLOUD_LLM_BASE_URL=https://www.dmxapi.cn/v1
CLOUD_LLM_API_KEY=sk-t4A0ixA3RFky4ZQ7EqwPcibMgvJEWD4mmBosqmxq3xUkjgkT

# Legacy aliases (向后兼容)
MINIMAX_MODEL_NAME=GLM-4.7-Flash
MINIMAX_BASE_URL=https://www.dmxapi.cn/v1
MINIMAX_API_KEY=sk-t4A0ixA3RFky4ZQ7EqwPcibMgvJEWD4mmBosqmxq3xUkjgkT

# =====================================================================
# Local 7B Configuration (Ollama)
# =====================================================================
LOCAL7B_BACKEND=ollama
LOCAL7B_API_BASE=http://localhost:11434
LOCAL7B_MODEL=qwen2.5-7b-instruct:latest
LOCAL7B_TIMEOUT=120.0

# =====================================================================
# Logging Configuration
# =====================================================================
LOG_LEVEL=INFO
LOG_DIR=logs

# =====================================================================
# Feature Flags
# =====================================================================
GM_OS_C3_THREE_CARDS_ENABLED=1

# RAG Feature Flags (Phase 1-6: 7B + 三维RAG + 数据飞轮 + 系统查询助手)
GM_OS_RAG_V01_ENABLED=1
GM_OS_RAG_QUALITY_CHECK_ENABLED=true
GM_OS_RAG_QUALITY_THRESHOLD=0.7
GM_OS_VAULT_AUTO_INDEX_ENABLED=true
GM_OS_QUERY_DEFAULT_MODE=unified

# =====================================================================
# opencode AI Assistant - 专用配置
# =====================================================================
# opencode API Key (从 https://opencode.ai 获取)
OPencode_API_KEY=your-opencode-api-key-here

# opencode 使用的底层模型 Key (可选 - 如果使用 OpenAI/Anthropic)
# OPencode_OPENAI_API_KEY=sk-your-openai-key-here
# OPencode_ANTHROPIC_API_KEY=sk-ant-your-key-here
