# =====================================================================
# SkillForge L4 API Environment Configuration
# Copy this file to .env and fill in your values
# =====================================================================

# =====================================================================
# LLM Configuration for /cognition/generate
# =====================================================================

# LLM Provider (openai, azure, mock for testing)
LLM_PROVIDER=openai

# Model to use for 10D cognition assessment
LLM_MODEL=gpt-4o-mini

# OpenAI API Key (required for openai provider)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Optional: Custom base URL for OpenAI-compatible APIs
# OPENAI_BASE_URL=https://api.openai.com/v1

# =====================================================================
# Alternative LLM Configuration (aliases)
# These are alternative names for the same settings
# =====================================================================
# CLOUD_LLM_MODEL=gpt-4o-mini
# CLOUD_LLM_API_KEY=sk-your-api-key-here
# CLOUD_LLM_BASE_URL=https://api.openai.com/v1

# =====================================================================
# Permit Signing Key (for work/execute endpoint)
# =====================================================================
PERMIT_HS256_KEY=your-secret-signing-key-here

# =====================================================================
# Logging Configuration
# =====================================================================
LOG_LEVEL=INFO
LOG_DIR=logs

# =====================================================================
# Feature Flags
# =====================================================================
# Enable/disable LLM integration (set to 1 to enable)
LLM_ENABLED=1
