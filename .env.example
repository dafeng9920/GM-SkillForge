# =====================================================================
# SkillForge L4 API Environment Configuration
# Copy this file to .env and fill in your values
# =====================================================================

# =====================================================================
# LLM Configuration for /cognition/generate
# =====================================================================

# LLM Provider (openai, azure, mock for testing)
LLM_PROVIDER=openai

# Model to use for 10D cognition assessment
LLM_MODEL=gpt-4o-mini

# OpenAI API Key (required for openai provider)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Optional: Custom base URL for OpenAI-compatible APIs
# OPENAI_BASE_URL=https://api.openai.com/v1

# =====================================================================
# DMX API Configuration (dmxapi.cn)
# =====================================================================
DMX_API_KEY=sk-your-dmx-api-key-here
DMX_API_BASE=https://www.dmxapi.cn/v1

# =====================================================================
# Permit Signing Key (for work/execute endpoint)
# =====================================================================
PERMIT_HS256_KEY=your-secret-signing-key-here

# =====================================================================
# Logging Configuration
# =====================================================================
LOG_LEVEL=INFO
LOG_DIR=logs

# =====================================================================
# Feature Flags
# =====================================================================
# Enable/disable LLM integration (set to 1 to enable)
LLM_ENABLED=1

# =====================================================================
# Quant System Configuration
# =====================================================================

# ===========================
# 数据库配置
# ===========================

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=quant_meta
POSTGRES_USER=quant_admin
POSTGRES_PASSWORD=quant_secure_change_me

# TDengine
TDEngine_HOST=localhost
TDEngine_PORT=6030
TDEngine_USER=root
TDEngine_PASSWORD=taosdata

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# MinIO
MINIO_ENDPOINT=localhost:9001
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin_change_me

# ===========================
# 数据源配置
# ===========================

# OpenBB
OPENBB_PROVIDER=yahoo
OPENBB_API_KEY=

# Yahoo Finance (备用)
YFINANCE_RATE_LIMIT=

# ===========================
# 交易配置
# ===========================

# VeighNa
VEIGHNA_GATEWAY=

# 模拟交易
PAPER_TRADING=true
PAPER_INITIAL_CAPITAL=1000000

# ===========================
# 系统配置
# ===========================

# 数据根目录
DATA_ROOT=./data

# ===========================
# 风控配置
# ===========================

# 最大回撤
MAX_DRAWDOWN=0.15

# 单日亏损限制
MAX_DAILY_LOSS=0.05

# 单标的仓位上限
MAX_POSITION_RATIO=0.3

# ===========================
# 监控配置
# ===========================

# Prometheus
PROMETHEUS_PORT=9090

# Grafana
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=admin_change_me
