{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gm-skillforge.local/schemas/openclaw_cloud_task_contract.schema.json",
  "title": "OpenClaw Cloud Task Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "task_id",
    "created_at_utc",
    "objective",
    "relay",
    "target",
    "policy",
    "command_allowlist",
    "acceptance",
    "required_artifacts",
    "contract_sha256"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "task_id": { "type": "string", "minLength": 8 },
    "created_at_utc": { "type": "string", "pattern": "Z$" },
    "objective": { "type": "string", "minLength": 3 },
    "relay": {
      "type": "object",
      "additionalProperties": false,
      "required": ["agent", "channel"],
      "properties": {
        "agent": { "type": "string", "minLength": 1 },
        "channel": { "type": "string", "minLength": 1 }
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["project_dir"],
      "properties": {
        "project_dir": { "type": "string", "minLength": 1 }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fail_closed", "max_duration_sec", "max_commands"],
      "properties": {
        "fail_closed": { "type": "boolean", "const": true },
        "max_duration_sec": { "type": "integer", "minimum": 30 },
        "max_commands": { "type": "integer", "minimum": 1 }
      }
    },
    "command_allowlist": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "acceptance": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "required_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "contract_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  }
}

