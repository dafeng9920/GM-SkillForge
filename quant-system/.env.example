# GM Quant System - 环境配置
# 复制此文件为 .env 并修改配置

# ============================================
# PostgreSQL 配置
# ============================================
POSTGRES_USER=quant
POSTGRES_PASSWORD=quant123
POSTGRES_DB=quant_system

# ============================================
# MinIO 配置
# ============================================
MINIO_USER=quantadmin
MINIO_PASSWORD=quant123456

# ============================================
# Grafana 配置
# ============================================
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin123

# ============================================
# 日志级别
# ============================================
LOG_LEVEL=INFO

# ============================================
# OpenBB 配置 (可选)
# ============================================
# OPENBB_PROVIDER=yahoo
# OPENBB_API_KEY=your_api_key

# ============================================
# VeighNa / CTP 配置
# ============================================
# CTP_BROKER_ID=9999
# CTP_USER_ID=your_userid
# CTP_PASSWORD=your_password
# CTP_MD_ADDRESS=tcp://180.168.146.187:10211
# CTP_TD_ADDRESS=tcp://180.168.146.187:10201

# ============================================
# Kronos 配置
# ============================================
KRONOS_MODEL_PATH=/models/kronos
KRONOS_DEFAULT_VERSION=kronos-small

# ============================================
# Gate 风控配置
# ============================================
GATE_MAX_POSITION_RATIO=0.1
GATE_MAX_DAILY_LOSS=0.05
GATE_MAX_DRAWDOWN=0.10

# ============================================
# 告警配置
# ============================================
# SLACK_WEBHOOK_URL=https://hooks.slack.com/xxx
# ALERT_EMAIL=admin@example.com
