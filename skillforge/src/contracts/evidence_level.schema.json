{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://gm-os.dev/contracts/evidence_level.schema.json",
  "title": "EvidenceLevel",
  "description": "T9 deliverable: Evidence level definitions (E1-E5) for test coverage. Provides a stable, minimal-bore definition of what counts as evidence at each level. Enforces 'no default strength' principle - evidence level must be explicitly declared.",
  "type": "object",
  "required": [
    "level_id",
    "level_name",
    "strength",
    "requirements",
    "acceptable_kinds",
    "validation_criteria"
  ],
  "properties": {
    "level_id": {
      "type": "string",
      "description": "Evidence level identifier (E1-E5)",
      "enum": ["E1", "E2", "E3", "E4", "E5"]
    },
    "level_name": {
      "type": "string",
      "description": "Human-readable level name"
    },
    "strength": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5,
      "description": "Strength ranking (1=weakest, 5=strongest)"
    },
    "requirements": {
      "type": "object",
      "description": "Requirements for this evidence level",
      "required": ["description", "minimum_artifacts"],
      "properties": {
        "description": {
          "type": "string",
          "description": "Detailed description of what this level means"
        },
        "minimum_artifacts": {
          "type": "string",
          "description": "Minimum artifacts required (e.g., 'test file + assertion')"
        },
        "replayable": {
          "type": "boolean",
          "description": "Whether evidence can be replayed/reproduced"
        },
        "automated": {
          "type": "boolean",
          "description": "Whether evidence is generated by automation"
        },
        "gate_required": {
          "type": "boolean",
          "description": "Whether gate decision is required for this level"
        }
      }
    },
    "acceptable_kinds": {
      "type": "array",
      "description": "Acceptable evidence kinds for this level",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "validation_criteria": {
      "type": "object",
      "description": "Criteria to validate evidence at this level",
      "required": ["must_have", "must_not_have"],
      "properties": {
        "must_have": {
          "type": "array",
          "description": "Required attributes for this level",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "must_not_have": {
          "type": "array",
          "description": "Forbidden attributes for this level",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "examples": {
      "type": "array",
      "description": "Example evidence configurations at this level",
      "items": {
        "$ref": "#/definitions/evidence_example"
      }
    }
  },
  "additionalProperties": false,
  "definitions": {
    "evidence_example": {
      "type": "object",
      "description": "Example evidence configuration",
      "required": ["description", "evidence_refs"],
      "properties": {
        "description": {
          "type": "string",
          "description": "Description of this example"
        },
        "evidence_refs": {
          "type": "array",
          "description": "Example evidence references",
          "items": {
            "type": "object",
            "required": ["kind", "locator"],
            "properties": {
              "kind": {
                "type": "string",
                "description": "Evidence kind"
              },
              "locator": {
                "type": "string",
                "description": "Example locator"
              }
            }
          }
        }
      }
    }
  }
}
