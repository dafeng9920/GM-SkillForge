{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://skillforge.org/schemas/credential_boundary.schema.json",
  "title": "Credential Boundary Definition",
  "description": "Defines the boundary rules for credentials and secrets in SkillForge external execution layer",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "credential_type": {
      "type": "string",
      "description": "Type identifier for the credential (e.g., 'api_token', 'ssh_key')",
      "minLength": 1
    },
    "sensitivity_level": {
      "type": "string",
      "description": "Sensitivity level (L0-L4)",
      "enum": ["L0", "L1", "L2", "L3", "L4"],
      "doc": {
        "L0": "Public - no restrictions",
        "L1": "Internal - organization visible only",
        "L2": "Sensitive - access control required",
        "L3": "Highly sensitive - strict access control, no frozen, no logs",
        "L4": "Secret - highest protection, HSM/KMS only"
      }
    },
    "masking_rule": {
      "type": "object",
      "description": "Masking rule for logging and reporting",
      "additionalProperties": false,
      "properties": {
        "pattern": {
          "type": "string",
          "description": "Mask pattern (e.g., 'sk-****')"
        },
        "show_first_n": {
          "type": "integer",
          "description": "Number of characters to show at the beginning",
          "minimum": 0,
          "default": 0
        },
        "show_last_n": {
          "type": "integer",
          "description": "Number of characters to show at the end",
          "minimum": 0,
          "default": 0
        },
        "mask_char": {
          "type": "string",
          "description": "Character used for masking",
          "minLength": 1,
          "maxLength": 1,
          "default": "*"
        },
        "exception_contexts": {
          "type": "array",
          "description": "Contexts where full credential may be logged (e.g., 'audit_trace')",
          "items": {
            "type": "string"
          },
          "default": []
        }
      },
      "required": ["pattern"]
    },
    "boundary_rules": {
      "type": "object",
      "description": "Boundary rules for credential usage",
      "additionalProperties": false,
      "properties": {
        "allowed_contexts": {
          "type": "array",
          "description": "Contexts where this credential type may be used",
          "items": {
            "type": "string",
            "enum": [
              "external_api_call",
              "external_service_auth",
              "webhook_signing",
              "data_encryption"
            ]
          }
        },
        "prohibited_contexts": {
          "type": "array",
          "description": "Contexts where this credential type must NOT appear",
          "items": {
            "type": "string",
            "enum": [
              "logging",
              "frozen_object",
              "config_file",
              "version_control",
              "database_storage"
            ]
          },
          "default": ["logging", "frozen_object", "config_file", "version_control"]
        },
        "min_distance_from_frozen": {
          "type": "integer",
          "description": "Minimum number of scope layers between credential and frozen objects",
          "minimum": 2,
          "default": 2
        }
      },
      "required": ["allowed_contexts", "prohibited_contexts"]
    },
    "format_requirements": {
      "type": "object",
      "description": "Format requirements for credential validation",
      "additionalProperties": false,
      "properties": {
        "min_length": {
          "type": "integer",
          "description": "Minimum credential length",
          "minimum": 0
        },
        "max_length": {
          "type": "integer",
          "description": "Maximum credential length",
          "minimum": 0
        },
        "prefix": {
          "type": "string",
          "description": "Required prefix (e.g., 'sk-' for API keys)"
        },
        "pattern": {
          "type": "string",
          "description": "Regex pattern for credential validation"
        },
        "encoding": {
          "type": "string",
          "description": "Expected encoding",
          "enum": ["utf-8", "ascii", "base64", "hex"],
          "default": "utf-8"
        }
      }
    },
    "lifecycle": {
      "type": "object",
      "description": "Lifecycle constraints (informational, not enforced by boundary)",
      "additionalProperties": false,
      "properties": {
        "rotation_policy": {
          "type": "string",
          "description": "Rotation policy reference",
          "enum": ["manual", "auto_30d", "auto_90d", "auto_custom"],
          "default": "manual"
        },
        "retention_days": {
          "type": "integer",
          "description": "Days to retain audit records for this credential",
          "minimum": 0,
          "default": 90
        }
      }
    }
  },
  "required": ["credential_type", "sensitivity_level", "boundary_rules"],
  "definitions": {
    "SensitivityLevel": {
      "type": "string",
      "enum": ["L0", "L1", "L2", "L3", "L4"],
      "description": "Sensitivity level for secrets classification"
    },
    "MaskingRule": {
      "type": "object",
      "properties": {
        "pattern": { "type": "string" },
        "show_first_n": { "type": "integer", "minimum": 0 },
        "show_last_n": { "type": "integer", "minimum": 0 },
        "mask_char": { "type": "string", "minLength": 1, "maxLength": 1 },
        "exception_contexts": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["pattern"]
    },
    "BoundaryRules": {
      "type": "object",
      "properties": {
        "allowed_contexts": { "type": "array", "items": { "type": "string" } },
        "prohibited_contexts": { "type": "array", "items": { "type": "string" } },
        "min_distance_from_frozen": { "type": "integer", "minimum": 2 }
      },
      "required": ["allowed_contexts", "prohibited_contexts"]
    },
    "CredentialRequirement": {
      "type": "object",
      "properties": {
        "credential_type": { "type": "string" },
        "sensitivity_level": { "$ref": "#/definitions/SensitivityLevel" },
        "masking_rule": { "$ref": "#/definitions/MaskingRule" },
        "boundary_rules": { "$ref": "#/definitions/BoundaryRules" },
        "format_requirements": { "type": "object" }
      },
      "required": ["credential_type", "sensitivity_level", "boundary_rules"]
    },
    "ComplianceViolation": {
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "message": { "type": "string" },
        "severity": { "type": "string", "enum": ["ERROR", "WARNING", "INFO"] },
        "credential_type": { "type": "string" }
      },
      "required": ["type", "message", "severity"]
    },
    "ComplianceReport": {
      "type": "object",
      "properties": {
        "is_compliant": { "type": "boolean" },
        "violations": {
          "type": "array",
          "items": { "$ref": "#/definitions/ComplianceViolation" }
        },
        "warnings": {
          "type": "array",
          "items": { "$ref": "#/definitions/ComplianceViolation" }
        }
      },
      "required": ["is_compliant"]
    }
  }
}
