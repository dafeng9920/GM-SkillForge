{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://gm-os.dev/orchestration/nodes/pack_audit_and_publish.schema.json",
  "title": "PackAuditAndPublishNode",
  "description": "Stage 7: 审计包与发布",
  "type": "object",
  "required": ["node_id", "input", "output"],
  "properties": {
    "node_id": { "const": "pack_audit_and_publish" },
    "stage": { "const": 7 },
    "input": {
      "type": "object",
      "required": ["provenance", "gate_decision", "test_report", "trace_path"],
      "properties": {
        "provenance": { "type": "object" },
        "gate_decision": { "type": "object" },
        "test_report": { "type": "object" },
        "trace_path": { "type": "string" },
        "visibility": { "type": "string", "enum": ["public", "private", "team"] }
      }
    },
    "output": {
      "type": "object",
      "required": ["audit_pack_path", "publish_result"],
      "properties": {
        "audit_pack_path": { "type": "string", "description": "audit_pack.zip 路径" },
        "publish_result": {
          "type": "object",
          "required": ["status"],
          "properties": {
            "status": { "type": "string", "enum": ["published", "rejected", "pending", "failed"] },
            "registry_url": { "type": "string", "format": "uri" },
            "skill_id": { "type": "string" },
            "version": { "type": "string" },
            "rejection_reasons": { "type": "array", "items": { "type": "object" } }
          }
        }
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["AUDIT_LINT_FAILED", "AUDIT_HASH_MISMATCH", "AUDIT_PROVENANCE_INCOMPLETE", "REG_REJECTED_INVALID_AUDIT", "REG_PUBLISH_VISIBILITY_DENIED"]
      }
    }
  },
  "version": "0.1.0"
}
