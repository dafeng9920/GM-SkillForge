{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://gm-os.dev/orchestration/nodes/sandbox_test_and_trace.schema.json",
  "title": "SandboxTestAndTraceNode",
  "description": "Stage 6: 测试样例与沙箱试跑",
  "type": "object",
  "required": ["node_id", "input", "output"],
  "properties": {
    "node_id": { "const": "sandbox_test_and_trace" },
    "stage": { "const": 6 },
    "input": {
      "type": "object",
      "required": ["scaffold_bundle_path", "gate_decision"],
      "properties": {
        "scaffold_bundle_path": { "type": "string" },
        "gate_decision": { "type": "object" },
        "test_cases": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "input": { "type": "object" },
              "expected_output": { "type": "object" }
            }
          }
        }
      }
    },
    "output": {
      "type": "object",
      "required": ["test_report", "trace_path"],
      "properties": {
        "test_report": {
          "type": "object",
          "required": ["total_runs", "passed", "failed"],
          "properties": {
            "total_runs": { "type": "integer", "minimum": 0 },
            "passed": { "type": "integer", "minimum": 0 },
            "failed": { "type": "integer", "minimum": 0 },
            "success_rate": { "type": "number", "minimum": 0, "maximum": 1 },
            "avg_latency_ms": { "type": "number" },
            "total_cost_usd": { "type": "number" }
          }
        },
        "trace_path": { "type": "string", "description": "run_trace.jsonl 路径" }
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["EXEC_TIMEOUT", "EXEC_TEST_INSUFFICIENT_RUNS", "EXEC_METRICS_THRESHOLD_FAILED", "SYS_INTERNAL"]
      }
    }
  },
  "version": "0.1.0"
}
