{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://gm-os.dev/schemas/tech_seo_audit.input.schema.json",
    "title": "TechSeoAuditInput",
    "description": "tech_seo_audit skill 的输入合同",
    "type": "object",
    "required": [
        "url"
    ],
    "properties": {
        "schema_version": {
            "$ref": "common.schema.json#/definitions/SchemaVersion"
        },
        "url": {
            "type": "string",
            "format": "uri",
            "description": "待审计的目标 URL"
        },
        "depth": {
            "type": "integer",
            "minimum": 1,
            "maximum": 10,
            "default": 1,
            "description": "爬取深度（1 = 仅当前页，>1 = 递归子页面）"
        },
        "checks": {
            "type": "array",
            "items": {
                "type": "string",
                "enum": [
                    "canonical",
                    "hreflang",
                    "structured_data",
                    "meta_tags",
                    "headings",
                    "images",
                    "links",
                    "performance",
                    "security",
                    "robots",
                    "sitemap"
                ]
            },
            "description": "要执行的检查类型（空 = 全部检查）"
        },
        "check_external_links": {
            "type": "boolean",
            "default": false,
            "description": "是否检查外部链接可达性"
        },
        "thresholds": {
            "type": "object",
            "properties": {
                "max_load_time_ms": {
                    "type": "integer",
                    "default": 3000
                },
                "max_page_size_bytes": {
                    "type": "integer",
                    "default": 5242880
                }
            },
            "description": "性能阈值配置"
        }
    },
    "additionalProperties": true,
    "version": "0.1.0"
}