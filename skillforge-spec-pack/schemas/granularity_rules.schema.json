{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://gm-os.dev/schemas/granularity_rules.schema.json",
  "title": "GranularityRules",
  "description": "Schema 颗粒度治理规则",
  "type": "object",
  "required": ["schema_version", "controls_catalog", "lint_rules", "risk_tier_minimums"],
  "properties": {
    "schema_version": { "$ref": "common.schema.json#/definitions/SchemaVersion" },
    "controls_catalog": {
      "type": "object",
      "description": "控制字段目录",
      "additionalProperties": {
        "type": "object",
        "required": ["type", "default"],
        "properties": {
          "type": { "type": "string" },
          "description": { "type": "string" },
          "default": {},
          "minimum": { "type": "number" },
          "maximum": { "type": "number" },
          "enum": { "type": "array" },
          "aliases": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "lint_rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["rule_id", "description", "check"],
        "properties": {
          "rule_id": { "type": "string" },
          "description": { "type": "string" },
          "severity": { "type": "string", "enum": ["error", "warning", "info"] },
          "check": {
            "type": "object",
            "required": ["type"],
            "properties": {
              "type": { "type": "string" },
              "field": { "type": "string" },
              "operator": { "type": "string" },
              "value": {},
              "reference": { "type": "string" }
            }
          },
          "required_changes_template": {
            "type": "object",
            "properties": {
              "kind": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        }
      }
    },
    "risk_tier_minimums": {
      "type": "object",
      "properties": {
        "L0": {
          "type": "object",
          "properties": {
            "required_controls": { "type": "array", "items": { "type": "string" } },
            "required_schema_depth": { "type": "integer" }
          }
        },
        "L1": {
          "type": "object",
          "properties": {
            "required_controls": { "type": "array", "items": { "type": "string" } },
            "required_schema_depth": { "type": "integer" }
          }
        },
        "L2": {
          "type": "object",
          "properties": {
            "required_controls": { "type": "array", "items": { "type": "string" } },
            "required_schema_depth": { "type": "integer" }
          }
        },
        "L3": {
          "type": "object",
          "properties": {
            "required_controls": { "type": "array", "items": { "type": "string" } },
            "required_schema_depth": { "type": "integer" }
          }
        }
      }
    }
  },
  "additionalProperties": true,
  "version": "0.1.0"
}
