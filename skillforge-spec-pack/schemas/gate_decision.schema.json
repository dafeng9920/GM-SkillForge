{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://gm-os.dev/schemas/gate_decision.schema.json",
  "title": "GateDecision",
  "description": "门禁裁决结果 - 四大硬合同之一",
  "type": "object",
  "required": ["schema_version", "gate_id", "node_id", "decision", "decided_at"],
  "properties": {
    "schema_version": {
      "$ref": "common.schema.json#/definitions/SchemaVersion"
    },
    "gate_id": {
      "$ref": "common.schema.json#/definitions/UUID"
    },
    "node_id": {
      "type": "string",
      "description": "触发门禁的编排节点 ID"
    },
    "job_id": {
      "$ref": "common.schema.json#/definitions/UUID"
    },
    "decision": {
      "type": "string",
      "enum": ["ALLOW", "DENY", "REQUIRES_CHANGES"],
      "description": "门禁裁决结果"
    },
    "risk_tier": {
      "$ref": "common.schema.json#/definitions/RiskTier"
    },
    "reasons": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "message"],
        "properties": {
          "code": { "$ref": "common.schema.json#/definitions/ErrorCode" },
          "message": { "type": "string" },
          "severity": { "type": "string", "enum": ["info", "warning", "error", "critical"] }
        }
      }
    },
    "required_changes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind", "description"],
        "properties": {
          "kind": {
            "type": "string",
            "enum": ["CONFIG_CHANGE", "PERMISSION_REDUCE", "ADD_LICENSE", "FIX_SCHEMA", "PIN_COMMIT", "OPTIMIZE", "RETRY"]
          },
          "description": { "type": "string" },
          "patch_hints": {
            "type": "array",
            "items": { "type": "string" }
          },
          "target_path": { "type": "string" }
        }
      }
    },
    "decided_at": { "$ref": "common.schema.json#/definitions/Timestamp" },
    "expires_at": { "$ref": "common.schema.json#/definitions/Timestamp" },
    "metadata": { "type": "object" }
  },
  "additionalProperties": true,
  "version": "0.1.0"
}
